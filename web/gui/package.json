{
  "name": "onetrainer",
  "version": "0.1.0",
  "description": "Electron-based Javascript interface for OneTrainer",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/main/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "generate-types": "node ../scripts/run_generate_types.js",
    "copy:splash": "node -e \"require('fs').cpSync('src/main/splash.html','dist/main/main/splash.html')\"",
    "rename:cjs": "node scripts/rename-cjs.mjs",
    "dev:electron": "tsc -p tsconfig.main.json && npm run copy:splash && npm run rename:cjs && concurrently -k --names \"vite,electron\" -c \"cyan,green\" \"vite\" \"electron .\"",
    "build": "vite build",
    "build:main": "tsc -p tsconfig.main.json && npm run copy:splash && npm run rename:cjs",
    "build:electron": "npm run generate-types && tsc -p tsconfig.main.json && npm run copy:splash && npm run rename:cjs && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "preview": "vite preview",
    "start": "electron ."
  },
  "build": {
    "extends": "electron-builder.yml"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.3.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^7.3.1"
  }
}
